generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid())
  name           String?
  firstName      String?
  lastName       String?
  ein            String?
  numberOfDependents Int?
  occupation     String?
  streetAddress  String?
  zipCode        String?
  city           String?
  state          String?
  country        String?
  filingStatus   String?
  username       String   @unique
  phone          String?  @unique
  email          String   @unique
  dateOfBirth    DateTime
  password       String
  ssn            String?
  profilePicture String?
  isVerified     Boolean  @default(false)
  isAdmin        Boolean  @default(false)
  googleId       String?  @unique
  otp            String?
  otpExpiresAt   DateTime?
  paystackCustomerId String? @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  filings        TaxFiling[]
  subscriptions  Subscription[]
  conversations  Conversation[] // <--- ADDED: Relation to Chat
  notifications Notification[]
}

model Subscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
}

model PricingPlan {
  id               String   @id @default(uuid())
  title            String
  features         String[]
  price            Float
  discount         Float?
  type             String
  paystackPlanCode String? @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  subscriptions    Subscription[]
}

model Subscription {
  id                      String   @id @default(uuid())
  userId                  String
  planId                  String
  paystackSubscriptionCode String? @unique
  paystackEmailToken      String?
  status                  String   @default("active")
  startDate               DateTime @default(now())
  nextPaymentDate         DateTime?
  endDate                 DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                    PricingPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}

enum FilingStatus {
  PENDING
  UNDER_REVIEW
  COMPLETED
  REJECTED
  NEEDS_INFO
}

enum ServiceType {
  CALCULATION_ONLY
  EXPERT_GUIDED
  FULL_FILING
}

model TaxFiling {
  id           String        @id @default(uuid())
  filingId     String        @unique
  userId       String
  serviceType  ServiceType   @default(FULL_FILING)
  taxYear      Int           @default(2024)
  type         String?
  status       FilingStatus  @default(PENDING)
  amount       Float?
  personalInfo Json?
  incomeDetails Json?
  deductions   Json?
  documents    Document[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relation
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id        String @id @default(uuid())
  name      String
  url       String
  type      String?
  filingId  String
  filing    TaxFiling @relation(fields: [filingId], references: [id], onDelete: Cascade)
}

enum ConversationType {
  AI
  AGENT
}

enum SenderType {
  USER
  ADMIN
  AI
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  VOICE
  STICKER
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      ConversationType @default(AGENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  Message[]
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String   // User ID or Admin ID or 'AI'
  senderType     SenderType
  content        String?  @db.Text // Text content or Sticker URL
  type           MessageType @default(TEXT)
  fileUrl        String?  // URL for files/images/voice notes
  reactions      Json?    // Store reactions like [{ userId: "1", emoji: "👍" }]
  createdAt      DateTime @default(now())

  @@index([conversationId])
}

enum NotificationType {
  FILING
  CHAT
  SYSTEM
  SUBSCRIPTION
}

enum NotificationPriority {
  HIGH
  LOW
}

model Notification {
  id        String @id @default(uuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType
  priority  NotificationPriority @default(LOW)
  
  title     String
  message   String
  link      String? // URL to the relevant resource (e.g., /filings/123)
  
  isRead    Boolean @default(false)
  createdAt DateTime @default(now())
}
